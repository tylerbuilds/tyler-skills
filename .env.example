# Copy to your shell environment or a local untracked .env file.
# Use a scoped Cloudflare API token, not the legacy Global API key.
CLOUDFLARE_API_TOKEN=

# Optional. Some account-level operations, such as Access and Turnstile,
# need an account ID as well as a zone ID.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

